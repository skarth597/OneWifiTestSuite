+
+		memcpy(s_tmp, &(spec->u.cfg80211.u.start_ap.ap_params.beacon.tail_len), sizeof(size_t));
+		s_tmp += sizeof(size_t);
+		*len += sizeof(size_t);
+
+		memcpy(s_tmp, &(spec->u.cfg80211.u.start_ap.ap_params.beacon.beacon_ies_len), sizeof(size_t));
+		s_tmp += sizeof(size_t);
