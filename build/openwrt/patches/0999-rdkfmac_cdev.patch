+const struct file_operations rdkfmac_fops = {
+	.owner = THIS_MODULE,
+	.open = rdkfmac_open,
+	.read = rdkfmac_read,
+	.write = rdkfmac_write,
+	.release = rdkfmac_release,
+	.poll = rdkfmac_poll
+};
