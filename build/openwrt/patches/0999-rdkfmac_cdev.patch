+                add_assoc_resp_msg->u.frm80211.u.frame.frame_len = assoc_resp_len;
+                add_assoc_resp_msg->u.frm80211.u.frame.frame = kzalloc(assoc_resp_len, GFP_KERNEL);
+                memcpy(add_assoc_resp_msg->u.frm80211.u.frame.frame, assoc_resp, assoc_resp_len);
+                memcpy(add_assoc_resp_msg->u.frm80211.u.frame.macaddr, assoc_resp->bssid, ETH_ALEN);
+                memcpy(add_assoc_resp_msg->u.frm80211.u.frame.client_macaddr, assoc_resp->da, ETH_ALEN);
+                push_to_char_device(add_assoc_resp_msg);
+        }
+
+        kfree(add_assoc_resp_msg);
+        return;
+}
+
+void push_frame_to_char_dev(void *data, unsigned int len)
+{
+	struct ieee80211_mgmt *mgmt;
+        unsigned int frame_len;
+        u16 fc;
+
+        if (data == NULL) {
+                printk("%s:%d Invalid data \n", __func__, __LINE__);
+                return;
+        }
+
+        mgmt = (struct ieee80211_mgmt *)data;
+        frame_len = len;
+        if (mgmt) {
+                fc = mgmt->frame_control;
+
+                printk("%s:%d FC: %d Frame type %d Subtype %d frame_len %d\n", __func__, __LINE__, fc, WLAN_FC_GET_TYPE(fc), WLAN_FC_GET_STYPE(fc), frame_len);
+
+                switch (WLAN_FC_GET_STYPE(fc)) {
+                        case WLAN_FC_STYPE_PROBE_REQ:
+                                //handle_frame_probe_req(mgmt, frame_len);
+                                break;
+                        case WLAN_FC_STYPE_PROBE_RESP:
+                                //handle_frame_probe_resp(mgmt, frame_len);
+                                break;
+                        case WLAN_FC_STYPE_ASSOC_REQ:
+                                //handle_frame_assoc_req(mgmt, frame_len);
+                                break;
+                        case WLAN_FC_STYPE_ASSOC_RESP:
+                                handle_frame_assoc_resp(mgmt, frame_len);
+                                break;
+                        case WLAN_FC_STYPE_AUTH:
+                                handle_frame_auth(mgmt, frame_len);
+                                break;
+                        case WLAN_FC_STYPE_DEAUTH:
+                                //handle_frame_deauth(mgmt, frame_len);
+                                break;
+                        case WLAN_FC_STYPE_DISASSOC:
+                                //handle_frame_disassoc(mgmt, frame_len);
+                                break;
+                        default:
+                                printk("%s:%d Not handling other frames as of now\n", __func__, __LINE__);
+                                break;
+                }
+        }
+
+        return;
+}
+
+void frame_data_to_char_dev(void *data, size_t data_len) 
+{
+	if (data != NULL) {
+		push_frame_to_char_dev(data, data_len);
+	}
+	return;
+}
+
+EXPORT_SYMBOL(frame_data_to_char_dev);
+
+unsigned int get_list_entries_count_in_char_device(void)
+{
+	unsigned count = 0;
+	struct list_head *ptr = &g_char_device.list_head;
+
+	for (ptr = &g_char_device.list_head; ptr != g_char_device.list_tail; ptr = ptr->next) {
+		count++;
+	}
+
+	return count;
+}
+
+wlan_emu_msg_data_t*pop_from_char_device(void)
+{
+	wlan_emu_msg_data_t *spec = NULL;
+	wlan_emu_msg_data_entry_t *entry = NULL;
+
+	if (g_char_device.list_tail == &g_char_device.list_head) {
+		printk("%s:%d list is empty\n", __func__, __LINE__);
+		return NULL;
+	}
+
+	entry = list_entry(g_char_device.list_tail, wlan_emu_msg_data_entry_t, list_entry);
+
+	g_char_device.list_tail= g_char_device.list_tail->prev;
+	list_del(&entry->list_entry);
+
+	spec = entry->spec;
+	kfree(entry);
+
+	return spec;
+}
+
+struct rdkfmac_device_data *get_char_device_data(void)
+{
+	return &g_char_device;
+}
